# Porta do servidor HTTP
PORT=4000

# Banco de dados (SQLite por padrão). Para Postgres, troque o provider no
# schema.prisma para "postgresql" e use uma URL como:
# postgresql://user:senha@localhost:5432/controle_financeiro
DATABASE_URL="file:./dev.db"

# Segredo usado para assinar os tokens JWT. GERE UM VALOR ALEATÓRIO E LONGO.
# Ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"

# Validade do token (formato aceito pelo jsonwebtoken, ex.: 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# Chave da API da Anthropic (fica SOMENTE no backend, nunca no frontend).
# Obtenha em https://console.anthropic.com/
# Sem ela, o lançamento por chat em linguagem natural (e o bot do Telegram)
# fica desabilitado.
ANTHROPIC_API_KEY=

# Origem permitida para CORS (URL do frontend). Use * apenas em desenvolvimento.
CORS_ORIGIN=http://localhost:5173

# Token do bot do Telegram (crie um com @BotFather no Telegram).
# Sem ele, a integração com o Telegram fica desabilitada.
TELEGRAM_BOT_TOKEN=

# Username do bot (sem @, ex.: MeuControleFinanceiroBot) — usado só para
# montar o link/instrução exibidos na tela de pareamento no app.
TELEGRAM_BOT_USERNAME=
