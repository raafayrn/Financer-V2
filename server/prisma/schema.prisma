// Prisma schema — Controle Financeiro
//
// Todos os valores monetários são armazenados em CENTAVOS (inteiros) para
// evitar erros de arredondamento de ponto flutuante. A conversão para reais
// acontece apenas na borda da API.
//
// Modelo de contas: cada usuário tem 3 contas fixas, criadas automaticamente
// no cadastro (ver seedAccountsForUser em src/lib/accounts.ts):
//   - CREDIT_CARD   ("Cartão de crédito")  — fatura mensal, fixos/variáveis
//   - FOOD_VOUCHER  ("Vale-alimentação")   — gasto do vale (ex.: energéticos)
//   - WALLET        ("Carteira (Pix)")     — saldo do mês = MonthlyWalletBase
//                     (base editável, ex.: o que sobrou/você já tinha) + soma
//                     dos Income do mês com accountId = wallet − soma das
//                     Expense do mês com accountId = wallet. NÃO acumula de
//                     mês a mês automaticamente (o usuário reajusta a base).
// `kind` identifica a conta de forma estável (não depender do nome, que o
// usuário poderia editar no futuro).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  categories     Category[]
  budgets        MonthlyBudget[]
  salaries       MonthlySalary[]
  vouchers       MonthlyVoucher[]
  walletBases    MonthlyWalletBase[]
  expenses       Expense[]
  incomes        Income[]
  accounts       Account[]
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([userId, name])
  @@index([userId])
}

model MonthlyBudget {
  id        String   @id @default(cuid())
  userId    String
  // Ano e mês (1-12) a que o orçamento se refere.
  year      Int
  month     Int
  // Valor do orçamento em centavos.
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}

// Salário fixo do mês — editado em Ajustes, igual ao orçamento. Renda do mês
// = MonthlySalary.amount + soma dos Income daquele mês.
model MonthlySalary {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  // Valor em centavos.
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}

// Vale-alimentação (VR) fixo do mês — editado no dashboard, junto com o
// salário. Renda do mês = MonthlySalary.amount + MonthlyVoucher.amount +
// soma dos Income avulsos (excluindo os ligados à Carteira, já refletidos
// no saldo acumulado dela).
model MonthlyVoucher {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  // Valor em centavos.
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}

// Saldo base da Carteira (Pix) do mês — editável pelo usuário (ex.: quanto
// ele já tinha na carteira no início do mês). Some com os Income/Expense do
// mês ligados à conta WALLET pra formar o saldo exibido no dashboard.
model MonthlyWalletBase {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  // Valor em centavos.
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}

enum AccountKind {
  CREDIT_CARD
  FOOD_VOUCHER
  WALLET
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  name      String
  kind      AccountKind
  createdAt DateTime    @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]
  incomes  Income[]

  @@unique([userId, kind])
  @@index([userId])
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  description String
  // Valor em centavos.
  amount      Int
  date        DateTime
  categoryId  String?
  accountId   String?
  recurring   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account  Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([categoryId])
}

// Lançamentos de renda avulsos (ex.: vale-alimentação convertido em Pix).
// Quando accountId aponta para a conta WALLET, credita o saldo da carteira.
model Income {
  id          String   @id @default(cuid())
  userId      String
  description String
  // Valor em centavos.
  amount      Int
  date        DateTime
  accountId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}
