// Prisma schema — Controle Financeiro
//
// Todos os valores monetários são armazenados em CENTAVOS (inteiros) para
// evitar erros de arredondamento de ponto flutuante. A conversão para reais
// acontece apenas na borda da API.
//
// Modelo de contas: cada usuário tem 3 contas fixas, criadas automaticamente
// no cadastro (ver seedAccountsForUser em src/lib/accounts.ts):
//   - CREDIT_CARD   ("Cartão de crédito")  — fatura mensal, fixos/variáveis
//   - FOOD_VOUCHER  ("Vale-alimentação")   — gasto do vale (ex.: energéticos)
//   - WALLET        ("Carteira (Pix)")     — saldo do mês = MonthlyWalletBase
//                     (base editável, ex.: o que sobrou/você já tinha) + soma
//                     dos Income do mês com accountId = wallet − soma das
//                     Expense do mês com accountId = wallet. NÃO acumula de
//                     mês a mês automaticamente (o usuário reajusta a base).
// `kind` identifica a conta de forma estável (não depender do nome, que o
// usuário poderia editar no futuro).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String
  // Chat ID do Telegram vinculado (via código de pareamento gerado no app).
  // Permite lançar despesas/receitas e tirar dúvidas pelo bot do Telegram.
  telegramChatId String?  @unique
  createdAt      DateTime @default(now())

  categories     Category[]
  budgets        MonthlyBudget[]
  salaries       MonthlySalary[]
  vouchers       MonthlyVoucher[]
  walletBases    MonthlyWalletBase[]
  expenses       Expense[]
  incomes        Income[]
  accounts       Account[]
  investments    Investment[]

  // Saúde — Treinos
  workoutDays      WorkoutDay[]
  workoutExercises WorkoutExercise[]
  workoutSessions  WorkoutSession[]
  workoutSets      WorkoutSetLog[]
  bodyMetrics      BodyMetric[]
  // Saúde — Água
  waterGoal        WaterGoal?
  waterEntries     WaterEntry[]
  // Estudos
  subjects         Subject[]
  topics           Topic[]
  exams            Exam[]
  studyTasks       StudyTask[]
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([userId, name])
  @@index([userId])
}

model MonthlyBudget {
  id        String   @id @default(cuid())
  userId    String
  // Ano e mês (1-12) a que o orçamento se refere.
  year      Int
  month     Int
  // Valor do orçamento em centavos.
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}

// Salário fixo do mês — editado em Ajustes, igual ao orçamento. Renda do mês
// = MonthlySalary.amount + soma dos Income daquele mês.
model MonthlySalary {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  // Valor em centavos.
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}

// Vale-alimentação (VR) fixo do mês — editado no dashboard, junto com o
// salário. Renda do mês = MonthlySalary.amount + MonthlyVoucher.amount +
// soma dos Income avulsos (excluindo os ligados à Carteira, já refletidos
// no saldo acumulado dela).
model MonthlyVoucher {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  // Valor em centavos.
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}

// Saldo base da Carteira (Pix) do mês — editável pelo usuário (ex.: quanto
// ele já tinha na carteira no início do mês). Some com os Income/Expense do
// mês ligados à conta WALLET pra formar o saldo exibido no dashboard.
model MonthlyWalletBase {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  // Valor em centavos.
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}

enum AccountKind {
  CREDIT_CARD
  FOOD_VOUCHER
  WALLET
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  name      String
  kind      AccountKind
  createdAt DateTime    @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]
  incomes  Income[]

  @@unique([userId, kind])
  @@index([userId])
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  description String
  // Valor em centavos.
  amount      Int
  date        DateTime
  categoryId  String?
  accountId   String?
  recurring   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account  Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([categoryId])
}

// Lançamentos de renda avulsos (ex.: vale-alimentação convertido em Pix).
// Quando accountId aponta para a conta WALLET, credita o saldo da carteira.
model Income {
  id          String   @id @default(cuid())
  userId      String
  description String
  // Valor em centavos.
  amount      Int
  date        DateTime
  accountId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

enum InvestmentType {
  RENDA_FIXA
  TESOURO_DIRETO
  ACOES
  FUNDOS
  CRIPTO
  POUPANCA
  OUTRO
}

// Registro de aportes/resgates de investimentos. `amount` é sempre positivo;
// `kind` indica se foi um aporte (soma ao total investido) ou um resgate
// (subtrai). O saldo total por tipo é a soma dos aportes menos os resgates.
enum InvestmentKind {
  APORTE
  RESGATE
}

model Investment {
  id          String         @id @default(cuid())
  userId      String
  description String
  type        InvestmentType
  kind        InvestmentKind @default(APORTE)
  // Valor em centavos, sempre positivo.
  amount      Int
  date        DateTime
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ============================================================
// SAÚDE — Treinos
// ============================================================
// Datas (date) são armazenadas às 12:00 UTC para evitar drift de fuso, igual
// aos lançamentos financeiros.

enum WorkoutKind {
  STRENGTH // musculação
  CARDIO   // corrida/cardio
  MIXED    // misto (musculação + cardio no mesmo dia)
  REST     // descanso
}

// Template semanal: o que treinar em cada dia da semana
// (weekday: 0 = Domingo ... 6 = Sábado). Define o "calendário semanal".
model WorkoutDay {
  id        String      @id @default(cuid())
  userId    String
  weekday   Int
  name      String
  kind      WorkoutKind @default(STRENGTH)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
  sessions  WorkoutSession[]

  @@unique([userId, weekday])
  @@index([userId])
}

// Exercício previsto no template de um dia (musculação: séries/reps alvo).
model WorkoutExercise {
  id          String   @id @default(cuid())
  userId      String
  dayId       String
  name        String
  muscleGroup String?
  targetSets  Int?
  targetReps  String? // ex.: "8-12"
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  day  WorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dayId])
}

// Sessão de treino efetivamente realizada numa data. dayId é o dia-template
// usado (pode ser nulo para um treino avulso fora da rotina).
model WorkoutSession {
  id          String      @id @default(cuid())
  userId      String
  date        DateTime
  dayId       String?
  title       String
  kind        WorkoutKind @default(STRENGTH)
  notes       String?
  durationMin Int? // duração total (útil para cardio)
  distanceKm  Float? // distância (cardio/corrida)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  day  WorkoutDay?     @relation(fields: [dayId], references: [id], onDelete: SetNull)
  sets WorkoutSetLog[]

  @@index([userId, date])
}

// Série registrada (carga + repetições). Base para a evolução de carga e PRs
// (recordes): consultar por exerciseName ao longo do tempo.
model WorkoutSetLog {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String
  exerciseName String
  muscleGroup  String?
  setIndex     Int      @default(1)
  weightKg     Float?
  reps         Int?
  createdAt    DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, exerciseName])
  @@index([sessionId])
}

// Peso corporal e medidas por data (um registro por dia).
model BodyMetric {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  weightKg  Float?
  bodyFat   Float? // percentual de gordura
  waistCm   Float?
  chestCm   Float?
  armCm     Float?
  hipCm     Float?
  thighCm   Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ============================================================
// SAÚDE — Água
// ============================================================

// Meta diária de hidratação em ml. Um registro por usuário (upsert).
model WaterGoal {
  id        String   @id @default(cuid())
  userId    String   @unique
  goalMl    Int      @default(3000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Cada registro rápido de água (ex.: +250ml). O consumo do dia é a soma das
// entries daquela data.
model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  amountMl  Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ============================================================
// ESTUDOS
// ============================================================

// Matéria/disciplina. Progresso = tópicos concluídos / total de tópicos.
model Subject {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#007aff")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics Topic[]
  exams  Exam[]
  tasks  StudyTask[]

  @@index([userId])
}

// Assunto/tópico de uma matéria (checklist).
model Topic {
  id        String   @id @default(cuid())
  userId    String
  subjectId String
  name      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subjectId])
}

// Prova/avaliação com data — usada na contagem regressiva.
model Exam {
  id        String   @id @default(cuid())
  userId    String
  subjectId String?
  title     String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

// Tarefa/entrega (trabalho, exercício) com prazo opcional.
model StudyTask {
  id        String    @id @default(cuid())
  userId    String
  subjectId String?
  title     String
  dueDate   DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId])
}
